.DS_Store
private/

# Parallel agent worktrees (see "Self-managed planning loop" in AGENTS.md).
# `.claude/skills/plan-next/SKILL.md` creates one git worktree per concurrent
# subagent under .worktrees/<issue-number>-<slug>/. Worktree contents are
# real git checkouts on real branches — diffs go to PRs, not into main.
.worktrees/

# Build artifacts (Xcode + SwiftPM derived data)
.build/
iOS/build/

# Xcode per-user state (open tabs, scroll position, scheme selection).
# Regenerated on every Xcode launch — never useful in git.
**/xcuserdata/
**/*.xcuserstate

# Editor-local config (VS Code / Cursor). Workspace-scoped settings like
# extension toggles are personal preferences, not project conventions —
# project-wide editor rules belong in .editorconfig and AGENTS.md.
.vscode/

# Fastlane (App Store metadata pipeline) — see iOS/fastlane/Fastfile.
# Generated metadata is regenerated from AppStore/*.md before every push,
# so it shouldn't live in git (the Markdown is the source of truth).
iOS/fastlane/metadata/
iOS/fastlane/report.xml
iOS/fastlane/README.md

# NOTE: iOS/fastlane/screenshots/ is intentionally NOT ignored. The deck is
# generated by `make appstore-screenshots` from real Swift code (see
# ScreenshotHarness.swift) and we want regressions to show up in PR diffs.
# It's also the source for `docs/scripts/sync-screenshots.sh`.
# `make appstore-beta` leftovers: gym (build_app) generates a preview HTML
# and a temp working dir alongside the Fastfile. The .ipa + .xcarchive land
# in iOS/build/ (already ignored above).
iOS/fastlane/Preview.html
iOS/fastlane/tmp/
iOS/vendor/bundle/
iOS/.bundle/

# Marketing site (Jekyll build artifacts; the source lives in docs/).
docs/_site/
docs/_site_test/
docs/.jekyll-cache/
docs/.jekyll-metadata
docs/vendor/bundle/
docs/.bundle/
