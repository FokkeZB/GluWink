# Deliverfile — defaults for `fastlane deliver` (push App Store metadata).
#
# This file is loaded automatically by both the `appstore` and `appstore_pull`
# lanes in the Fastfile. Keep it focused on shared options; lane-specific
# overrides go in the Fastfile.

app_identifier "nl.fokkezb.GluWink"

# Where the per-locale text lives (generated from ../AppStore/*.md by
# `bundle exec fastlane sync_metadata`). Treated as the source of truth
# during a push; never edit by hand.
metadata_path "./fastlane/metadata"

# Screenshots are regenerated by `make appstore-screenshots` (see
# .claude/skills/appstore-screenshots/) and land under fastlane/screenshots/
# in the layout deliver expects — one folder per App Store locale, with
# `NN_<scene>.png` files directly inside it. No device-size subfolder:
# deliver's loader (`deliver/lib/deliver/loader.rb`) globs PNGs flat from
# each locale folder and doesn't recurse, so any subdir (e.g. `iPhone-6.9/`)
# is silently ignored and the upload reports success with zero images
# transferred. The device tier is detected from the PNG pixel dimensions
# (1320×2868 → APP_IPHONE_67, which ASC accepts for 6.9" devices too).
# Captions are baked into each PNG by `CaptionBanner.swift` from the
# per-locale AppStore/<locale>.md, so App Store Connect's (now-removed)
# per-screenshot caption field is not used. See QUIRKS.md → "Fastlane
# deliver ignores device-size subfolders" and issue #95.
screenshots_path "./fastlane/screenshots"
skip_screenshots false
# Only upload screenshots for locales present under screenshots_path; don't
# wipe other locales' decks on ASC if we haven't regenerated them yet.
overwrite_screenshots true

# We're not uploading a binary here — that still happens via Xcode / Transporter.
skip_binary_upload true

# Don't auto-submit; review submission stays a manual click in App Store Connect.
submit_for_review false

# Fail fast on metadata problems instead of warning.
precheck_include_in_app_purchases false
force false
