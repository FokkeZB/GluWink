# Fastfile — App Store Connect automation for GluWink.
#
# Auth: requires an App Store Connect API key JSON at `private/asc-api-key.json`
# (gitignored). See AppStore/README.md → "App Store Connect API key" for how to
# create one in App Store Connect → Users and Access → Integrations → Keys.

default_platform(:ios)
opt_out_usage

API_KEY_PATH     = "../../private/asc-api-key.json"     # repo-root /private/, from iOS/fastlane/
REVIEW_INFO_PATH = "../../private/asc-review-info.json" # ditto — App Review Contact Info + demo + notes
SYNC_SCRIPT      = File.expand_path("scripts/sync_metadata.rb", __dir__)

# Review info fields fastlane will accept on `deliver(app_review_information: …)`.
REVIEW_INFO_KEYS = %i[first_name last_name phone_number email_address demo_user demo_password notes].freeze

# These four are the ones App Store Connect rejects when blank. demo_user /
# demo_password / notes are optional — GluWink doesn't require login.
REVIEW_INFO_REQUIRED = %i[first_name last_name phone_number email_address].freeze

def require_api_key!
  abs = File.expand_path(API_KEY_PATH, __dir__)
  return abs if File.exist?(abs)

  UI.user_error!(
    "Missing App Store Connect API key at #{abs}.\n" \
    "Create one at https://appstoreconnect.apple.com/access/integrations/api " \
    "and save it as JSON with this shape:\n" \
    "{\n" \
    "  \"key_id\": \"ABCDE12345\",\n" \
    "  \"issuer_id\": \"00000000-0000-0000-0000-000000000000\",\n" \
    "  \"key\": \"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\",\n" \
    "  \"in_house\": false\n" \
    "}"
  )
end

# Load App Review Contact Info from private/asc-review-info.json. Returns a
# symbol-keyed hash ready to pass as `deliver(app_review_information: …)`, or
# `nil` if the file is absent (so day-to-day text-only pushes still work).
# Errors loudly if the file is present but missing required values — those are
# exactly the fields ASC rejects with HTTP 409.
def load_review_info
  require "json"

  abs = File.expand_path(REVIEW_INFO_PATH, __dir__)
  unless File.exist?(abs)
    UI.important(
      "No #{REVIEW_INFO_PATH} found — skipping App Review Contact Info upload. " \
      "Fill it in before submitting for review."
    )
    return nil
  end

  data = JSON.parse(File.read(abs))
  missing = REVIEW_INFO_REQUIRED.select { |k| data[k.to_s].to_s.strip.empty? }
  unless missing.empty?
    UI.user_error!(
      "App Review contact info at #{abs} is missing required values: " \
      "#{missing.join(', ')}.\n" \
      "Phone number must include the country code, e.g. '+31 6 1234 5678'."
    )
  end

  REVIEW_INFO_KEYS.each_with_object({}) { |k, h| h[k] = data[k.to_s] if data.key?(k.to_s) }
end

platform :ios do
  desc "Regenerate fastlane/metadata/* from AppStore/<locale>.md"
  lane :sync_metadata do |options|
    args = Array(options[:locales]).join(" ")
    sh("ruby #{SYNC_SCRIPT.shellescape} #{args}")
  end

  desc "Push App Store listing metadata (regenerates from Markdown first)."
  desc "Run with `locales:en-US,nl-NL` to scope to specific locales."
  lane :push_metadata do |options|
    sync_metadata(locales: (options[:locales] || "").split(","))
    api_key_path = require_api_key!

    # Wipe any stale `metadata/review_information/` directory left over from a
    # previous `pull_metadata`. fastlane unconditionally PATCHes whatever is in
    # there, and empty/blank files trigger HTTP 409 from ASC. Authoritative
    # review info now lives in `private/asc-review-info.json` and is passed
    # explicitly via `app_review_information:` below.
    review_dir = File.expand_path("metadata/review_information", __dir__)
    FileUtils.rm_rf(review_dir) if File.exist?(review_dir)

    # Workaround for fastlane bug: deliver crashes on brand-new versions because
    # `review_attachment_file` calls `fetch_app_store_review_detail` without
    # rescuing the empty-body response. Pre-create the record so the fetch
    # returns a real model. Idempotent — does nothing if it already exists.
    ensure_review_detail!(api_key_path)

    deliver_options = {
      api_key_path: api_key_path,
      force: true, # skip the HTML preview prompt
      run_precheck_before_submit: false,
    }

    review_info = load_review_info
    deliver_options[:app_review_information] = review_info if review_info

    deliver(**deliver_options)
  end

  # Make sure the editable App Store version has an AppStoreReviewDetail record.
  # Without one, fastlane 2.232.2 `deliver` blows up with "No data" inside
  # `review_attachment_file`. Real review info still has to be filled in inside
  # App Store Connect (or via `app_review_information:` on `deliver`).
  def ensure_review_detail!(api_key_path)
    require "spaceship"
    require "json"

    key = JSON.parse(File.read(api_key_path))
    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(
      key_id: key["key_id"],
      issuer_id: key["issuer_id"],
      key: key["key"],
    )

    app = Spaceship::ConnectAPI::App.find("nl.fokkezb.GluWink")
    UI.user_error!("App nl.fokkezb.GluWink not found in App Store Connect") unless app

    version = app.get_edit_app_store_version
    unless version
      UI.message("No editable version found — nothing to bootstrap.")
      return
    end

    detail = begin
      version.fetch_app_store_review_detail
    rescue => e
      UI.message("No review detail yet (#{e.message.lines.first.to_s.strip}); creating one.")
      nil
    end

    if detail
      UI.message("App review detail already exists — skipping bootstrap.")
    else
      version.create_app_store_review_detail(attributes: { demo_account_required: false })
      UI.success("Created empty App Review Information record.")
    end
  end

  desc "Download current App Store metadata into fastlane/metadata/ (read-only)."
  desc "Useful to inspect what Apple has, or to bootstrap a new locale."
  lane :pull_metadata do
    api_key_path = require_api_key!
    # `deliver download_metadata` is a CLI subcommand, not a Fastfile action,
    # so shell out. `--force` skips the confirmation prompt.
    sh(
      "bundle", "exec", "fastlane", "deliver", "download_metadata",
      "--api_key_path", api_key_path,
      "--app_identifier", "nl.fokkezb.GluWink",
      "--metadata_path", File.expand_path("metadata", __dir__),
      "--force",
    )
    UI.message(
      "Downloaded metadata is in iOS/fastlane/metadata/ — treat it as a snapshot. " \
      "The source of truth is AppStore/<locale>.md."
    )
  end
end
